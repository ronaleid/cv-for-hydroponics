#!/usr/bin/env python3
import os, sys
import cv2
import requests

API_KEY   = os.getenv("ROBOFLOW_API_KEY")
WS        = os.getenv("ROBOFLOW_WORKSPACE")     # required in many hosted endpoints
PROJECT   = os.getenv("ROBOFLOW_PROJECT", "lettuce-pi-test")
VERSION   = os.getenv("ROBOFLOW_VERSION", "1")

if not API_KEY:
    raise SystemExit("Missing ROBOFLOW_API_KEY")
if not WS:
    raise SystemExit("Missing ROBOFLOW_WORKSPACE (find it in your Roboflow project URL).")

# Hosted inference endpoint
URL = f"https://detect.roboflow.com/{WS}/{PROJECT}/{VERSION}?api_key={API_KEY}&format=json&confidence=0.4&overlap=0.3"

def infer(image_path: str):
    bgr = cv2.imread(image_path)
    if bgr is None:
        raise SystemExit(f"Could not read image: {image_path}")

    ok, jpg = cv2.imencode(".jpg", bgr, [int(cv2.IMWRITE_JPEG_QUALITY), 90])
    if not ok:
        raise SystemExit("Failed to encode JPG.")

    r = requests.post(
        URL,
        data=jpg.tobytes(),
        headers={"Content-Type": "application/x-www-form-urlencoded"},
        timeout=60
    )
    r.raise_for_status()
    js = r.json()

    preds = js.get("predictions", [])
    print("Endpoint:", URL.split("?")[0])
    print("Predictions:", len(preds))
    if preds:
        print("Prediction keys:", list(preds[0].keys()))
        print("First prediction:", preds[0])

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: python3 roboflow_infer.py /path/to/image.jpg")
        sys.exit(1)
    infer(sys.argv[1])

