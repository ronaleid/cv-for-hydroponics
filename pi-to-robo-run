# 1) upload script
# save as ~/hydro/upload_to_roboflow.py

#!/usr/bin/env python3
import os
from pathlib import Path
from roboflow import Roboflow

# ---- CONFIG ----
WORKSPACE = "rona-u8uj2"
PROJECT   = "lettuce-pi-test-zpydv"

# Local folder where your timer saves images
SRC_DIR   = Path("/home/ronaleipi/lettuce_imgs")

# Track what we've already uploaded so we don't re-upload
TRACK_FILE = Path("/home/ronaleipi/hydro/roboflow_uploaded.txt")

API_KEY = os.getenv("ROBOFLOW_API_KEY")
if not API_KEY:
    raise SystemExit("Set ROBOFLOW_API_KEY first: export ROBOFLOW_API_KEY='...'")

def load_uploaded_set() -> set[str]:
    if TRACK_FILE.exists():
        return set(TRACK_FILE.read_text().splitlines())
    return set()

def mark_uploaded(path: Path):
    TRACK_FILE.parent.mkdir(parents=True, exist_ok=True)
    with TRACK_FILE.open("a") as f:
        f.write(str(path) + "\n")

def main():
    rf = Roboflow(api_key=API_KEY)
    project = rf.workspace(WORKSPACE).project(PROJECT)

    uploaded = load_uploaded_set()

    # Pick image types (include uppercase too)
    exts = {".jpg", ".jpeg", ".png", ".JPG", ".JPEG", ".PNG"}
    images = sorted([p for p in SRC_DIR.iterdir() if p.suffix in exts])

    if not images:
        print("No images found in", SRC_DIR)
        return

    # Use today's date as a batch name (groups images nicely in Roboflow UI)
    batch_name = Path().resolve().name  # safe fallback
    # Better: set batch to today's folder name if you store by date; otherwise:
    from datetime import datetime
    batch_name = datetime.now().strftime("pi-upload-%Y-%m-%d")

    sent = 0
    for img in images:
        if str(img) in uploaded:
            continue

        # Upload to Roboflow project (no labels yet; you'll label in UI later)
        project.upload(
            image_path=str(img),
            batch_name=batch_name,
            num_retry_uploads=3
        )
        mark_uploaded(img)
        sent += 1
        print("Uploaded:", img.name)

    print(f"Done. Uploaded {sent} new images to {WORKSPACE}/{PROJECT} batch={batch_name}")

if __name__ == "__main__":
    main()

#run manually (upload new images)
source ~/venvs/rfupload/bin/activate
python3 ~/hydro/upload_to_roboflow.py

